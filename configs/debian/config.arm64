# Debian arm64-specific config fragments

CONFIG_64BIT=y
CONFIG_ARM64=y

# CPU features
CONFIG_ARM64_SVE=y
CONFIG_ARM64_SME=y
CONFIG_ARM64_PTR_AUTH=y
CONFIG_ARM64_BTI=y
CONFIG_ARM64_MTE=y

# Virtualisation
CONFIG_KVM=m

# ACPI / UEFI
CONFIG_ACPI=y
CONFIG_EFI=y
CONFIG_EFI_STUB=y

# Common ARM64 SoC support
CONFIG_ARCH_SUNXI=y
CONFIG_ARCH_ROCKCHIP=y
CONFIG_ARCH_BCM2835=y
CONFIG_ARCH_QCOM=y
